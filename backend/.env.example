# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://weather_user:weather_pass@127.0.0.1:5433/weather_db

# OpenWeatherMap API key — get one free at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_key_here

# Allowed frontend origins (JSON array format)
# Development default: localhost Vite dev server + preview
# Production: set to your actual frontend URL
CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]
